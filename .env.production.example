# ============================================================
# RestoPOS — Production environment template (Laravel Forge)
# ============================================================
# Copy this file to .env on the production server and fill in
# the values. Never commit a populated .env to version control.

APP_NAME="FORRIS POS"
APP_ENV=production
APP_KEY=                                  # generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://pos.forris.uz
APP_TIMEZONE=Asia/Tashkent
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

# ─── Logging ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# ─── Database ────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=forris_pos
DB_USERNAME=forris_pos
DB_PASSWORD=                              # set in Forge env vars

# ─── Redis (cache + sessions + queues + horizon) ─────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                           # if Redis is password-protected

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.pos.forris.uz             # cross-subdomain auth

QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=redis

# ─── Mail (TLS via SES/Postmark/Mailgun/SMTP) ────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@forris.uz
MAIL_FROM_NAME="${APP_NAME}"

# ─── Filesystem (S3 for uploads recommended) ─────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Multi-tenant ────────────────────────────────────────────
FORRIS_POS_MULTI_TENANT=true
FORRIS_POS_BASE_DOMAIN=pos.forris.uz
FORRIS_POS_ADMIN_SUBDOMAIN=admin
FORRIS_POS_DEFAULT_CURRENCY=UZS
FORRIS_POS_FISCAL_ENABLED=false
FORRIS_POS_FISCAL_PROVIDER=

# ─── SMS (PlayMobile in production) ──────────────────────────
SMS_DRIVER=playmobile
SMS_SENDER_ID=FORRIS
PLAYMOBILE_ENDPOINT=https://send.smsxabar.uz
PLAYMOBILE_USERNAME=
PLAYMOBILE_PASSWORD=

# ─── Payment providers ───────────────────────────────────────
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ─── Telegram (admin notifications) ──────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Maps ────────────────────────────────────────────────────
YANDEX_MAPS_API_KEY=

# ─── Reverb / Pusher (websockets) ────────────────────────────
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Horizon (queue dashboard auth) ──────────────────────────
HORIZON_ALLOWED_EMAILS=admin@forris.uz

# ─── Sentry (error tracking) ─────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ─── Debugging (must be off in production) ───────────────────
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false
