{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [120],
  "editor.wordWrap": "on",
  
  "files.associations": {
    "*.blade.php": "blade",
    ".env*": "dotenv"
  },
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/vendor": true,
    "**/.idea": true,
    "**/storage/framework/cache": true,
    "**/storage/framework/sessions": true,
    "**/storage/framework/views": true
  },
  
  "emmet.includeLanguages": {
    "blade": "html"
  },
  
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  
  "[blade]": {
    "editor.defaultFormatter": "shufo.vscode-blade-formatter",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.autoClosingBrackets": "always"
  },
  
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  
  "php.validate.executablePath": "/usr/bin/php",
  "php.suggest.basic": false,
  
  "intelephense.files.maxSize": 5000000,
  "intelephense.environment.phpVersion": "8.3.0",
  "intelephense.format.braces": "k&r",
  "intelephense.diagnostics.undefinedTypes": true,
  "intelephense.diagnostics.undefinedFunctions": true,
  "intelephense.diagnostics.undefinedConstants": true,
  "intelephense.diagnostics.undefinedClassConstants": true,
  "intelephense.diagnostics.undefinedMethods": true,
  "intelephense.diagnostics.undefinedProperties": true,
  "intelephense.diagnostics.undefinedVariables": true,
  
  "laravel-blade.format.enable": true,
  
  "tailwindCSS.includeLanguages": {
    "blade": "html"
  },
  "tailwindCSS.emmetCompletions": true,
  
  "phpcs.standard": "PSR12",
  
  "phpSniffer.executablesFolder": "./vendor/bin/",
  "phpSniffer.standard": "PSR12",
  
  "livewire.snippets": true,
  
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "bash",
  
  "search.exclude": {
    "**/vendor": true,
    "**/node_modules": true,
    "**/storage": true,
    "**/bootstrap/cache": true,
    "**/.git": true
  },
  
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "BUG",
    "HACK",
    "NOTE",
    "XXX"
  ],
  
  "cSpell.words": [
    "restopos",
    "livewire",
    "tailwindcss",
    "intelephense",
    "phpcs",
    "laravel",
    "eloquent",
    "artisan",
    "middleware",
    "sanctum",
    "seeders",
    "filament"
  ],
  
  "testing.automaticallyOpenPeekView": "failureVisible",
  
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2
  },
  
  "docker.containers.label": "Status",
  
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false
}
