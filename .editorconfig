# RestoPOS EditorConfig
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# PHP files
[*.php]
indent_size = 4

# Blade templates
[*.blade.php]
indent_size = 4

# JavaScript, TypeScript
[*.{js,jsx,ts,tsx,vue}]
indent_size = 2

# CSS, SCSS
[*.{css,scss,sass,less}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# XML
[*.xml]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2
end_of_line = lf

# Batch files (Windows)
[*.{bat,cmd}]
end_of_line = crlf

# PowerShell
[*.ps1]
indent_size = 4

# Makefile (tabs required)
[Makefile]
indent_style = tab

# Docker
[Dockerfile]
indent_size = 2

[docker-compose*.yml]
indent_size = 2

# Composer/NPM
[{composer,package}.json]
indent_size = 2

# Git
[.git*]
indent_size = 2
