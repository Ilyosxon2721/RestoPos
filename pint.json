{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": false,
        "ordered_imports": {
            "sort_algorithm": "alpha",
            "imports_order": ["class", "function", "const"]
        },
        "ordered_traits": true,
        "no_unused_imports": true,
        "concat_space": {"spacing": "none"},
        "not_operator_with_successor_space": false,
        "single_quote": true
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor",
        "node_modules"
    ]
}
