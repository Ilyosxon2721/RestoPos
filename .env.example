# RestoPOS Environment Configuration
# Copy this file to .env and update values

APP_NAME=RestoPOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tashkent
APP_URL=http://localhost:8000
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=restopos
DB_USERNAME=root
DB_PASSWORD=

# Docker Database (uncomment for Docker)
# DB_HOST=mysql
# DB_USERNAME=restopos
# DB_PASSWORD=secret

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Docker Redis (uncomment for Docker)
# REDIS_HOST=redis

# Cache & Session
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Queue
QUEUE_CONNECTION=redis

# Mail (Mailpit for development)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@restopos.local"
MAIL_FROM_NAME="${APP_NAME}"

# Docker Mail (uncomment for Docker)
# MAIL_HOST=mailpit

# Filesystem
FILESYSTEM_DISK=local

# Broadcasting
BROADCAST_CONNECTION=redis

# AWS (for production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Meilisearch (optional)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=masterkey

# Docker Meilisearch (uncomment for Docker)
# MEILISEARCH_HOST=http://meilisearch:7700

# Pusher (for real-time features)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# RestoPOS Specific
RESTOPOS_MULTI_TENANT=true
RESTOPOS_BASE_DOMAIN=resto.uz
RESTOPOS_ADMIN_SUBDOMAIN=admin
RESTOPOS_DEFAULT_CURRENCY=UZS
RESTOPOS_FISCAL_ENABLED=false
RESTOPOS_FISCAL_PROVIDER=

# SMS Provider (for OTP)
SMS_PROVIDER=playmobile
SMS_API_KEY=
SMS_SENDER_ID=RestoPOS

# Payment Providers
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Debugging
TELESCOPE_ENABLED=true
DEBUGBAR_ENABLED=true
